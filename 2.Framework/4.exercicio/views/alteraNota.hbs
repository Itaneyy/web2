<h2>Alteração de Atividade</h2>

<form method="POST" action="/atividade/altera/{{chave}}">
  <p>
    <label for="titulo">Título</label>
  </p>
  <p>
    <input
      type="text"
      name="titulo"
      id="titulo"
      value="{{titulo}}"
      size="60"
    />
  </p>

  <p>
    <label for="desc">Descrição da Nota</label>
  </p>
  <p>
    <textarea rows="5" cols="57" name="desc" id="desc">{{desc}}</textarea>
  </p>

  <p>
    <label for="prioridade">Prioridade da atividade</label>
  </p>
  <select name="prioridade" id="prioridade">
    {{!-- O helper 'eq' verifica se a prioridade vinda do banco é igual à opção --}}
    <option value="Alta" {{#if (eq prioridade "Alta")}}selected{{/if}}>Alta</option>
    <option value="Média" {{#if (eq prioridade "Média")}}selected{{/if}}>Média</option>
    <option value="Baixa" {{#if (eq prioridade "Baixa")}}selected{{/if}}>Baixa</option>
  </select>

  <p>
    <label for="executada">
      {{!-- Se executada for true, o atributo 'checked' é adicionado --}}
      <input 
        type="checkbox" 
        name="executada" 
        id="executada" 
        {{#if executada}}checked{{/if}} 
      /> 
      Atividade Executada
    </label>
  </p>

  <hr>

  <a href="/">
    <input type="button" value="Cancelar" />
  </a>
  
  {{!-- Input oculto para manter a chave/id se necessário --}}
  <input type="hidden" name="chave" value="{{chave}}">
  
  <button type="submit">Salvar Alterações</button>
</form>