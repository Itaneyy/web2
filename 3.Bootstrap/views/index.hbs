<nav class="navBack mb-4 p-3 w-100">
  <div class="row align-items-center">

    <div class="col-auto">
      <h1 class="m-0">Notas</h1>
    </div>

    <div class="col d-none d-lg-block">
      <div class="d-flex gap-3 itens-gray">
        <a href="/"> <i class="bi bi-house"></i>Home</a>
        <a href="/sobre"> <i class="bi bi-info-square"></i> Sobre</a>
        <a href="/nota/cria"> <i class="bi bi-envelope-plus"></i>Criar Nota</a>
        <a href="/nota/criaNotasTeste"><i class="bi bi-file-plus"></i>Criar
          Notas de Teste</a>
      </div>
    </div>

    <div class="col text-end d-block d-lg-none">
      <button
        class="btn border-0 p-0 text-dark"
        type="button"
        data-bs-toggle="offcanvas"
        data-bs-target="#menuResponsivo"
      >
        <i class="bi bi-justify fs-2"></i>
      </button>
    </div>

  </div>
</nav>

<div class="offcanvas offcanvas-end" tabindex="-1" id="menuResponsivo">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title">Navegação</h5>
    <button
      type="button"
      class="btn-close"
      data-bs-dismiss="offcanvas"
    ></button>
  </div>
  <div class="offcanvas-body">
    <div class="d-flex flex-column gap-3 itens-gray">
      <a href="/"> <i class="bi bi-house"></i>Home</a>
      <a href="/sobre"> <i class="bi bi-info-square"></i> Sobre</a>
      <a href="/nota/cria"> <i class="bi bi-envelope-plus"></i>Criar Nota</a>
      <a href="/nota/criaNotasTeste"><i class="bi bi-file-plus"></i>Criar Notas
        de Teste</a>
    </div>
  </div>
</div>

{{#if vazio}}
  <p>
    <b><i>Ainda não tem nenhuma atividade cadastrada</i></b>
  </p>

  <p>
    <a href="/nota/cria">Cadastre sua primeira atividade</a>
  </p>

{{else}}

  <div class="border rounded overflow-hidden">

    <div
      class="row table-primary text-center fw-bold p-2 align-items-center border-bottom bg-light"
    >
      <div class="col-lg-2 d-none d-lg-block">Chave</div>
      <div class="col-12 col-md-8 col-lg-8">Título</div>
      <div class="col-4 col-lg-2 d-none d-md-block">Alterar Status</div>
    </div>

    {{#each notas}}
      <div
        class="row text-center align-items-center m-0 border-bottom bg-white"
      >
        {{#if this.lida}}

          <div class="col-lg-2 d-none d-lg-block p-2">
            {{this.chave}}
          </div>

          <div class="col-12 col-md-8 col-lg-8 p-2 text-start">
            <a href="/nota/consulta/{{this.chave}}">
              {{this.titulo}}
            </a>
          </div>

          <div class="col-4 col-lg-2 d-none d-md-block p-2">
            <a href="/nota/naolida/{{this.chave}}">
              <i class="bi bi-envelope-open"></i>
            </a>
          </div>

        {{else}}

          <div class="col-lg-2 d-none d-lg-block p-2">
            <b>{{this.chave}}</b>
          </div>

          <div class="col-12 col-md-8 col-lg-8 p-2 text-start">
            <a href="/nota/consulta/{{this.chave}}">
              <b>

                {{this.titulo}}
              </b>
            </a>
          </div>

          <div class="col-4 col-lg-2 d-none d-md-block p-2">
            <b>
              <a href="/nota/lida/{{this.chave}}">
                <i class="bi bi-envelope-fill"></i>
              </a>
            </b>
          </div>

        {{/if}}
      </div>
    {{/each}}

  </div>

{{/if}}