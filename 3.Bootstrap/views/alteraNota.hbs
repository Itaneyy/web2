<div class="p-4">
  <h2 class="mb-4">Alteração de nota de texto</h2>

  <form method="POST" action="/nota/altera/{{chave}}" class="row g-3">

    <div class="col-12 col-md-6 col-lg-3">
      <label class="form-label" for="chave">Chave</label>
      <input
        class="form-control"
        required
        type="text"
        name="chave"
        value="{{chave}}"
        readonly
      />
    </div>

    <div class="col-12 col-md-6 col-lg-3">
      <label class="form-label" for="importancia">Importância da Nota</label>
      <input
        class="form-control"
        type="number"
        name="importancia"
        id="importancia"
        max="5"
        min="1"
        value="{{importancia}}"
      />
    </div>

    <div class="col-12 col-lg-6">
      <label class="form-label" for="titulo">Título</label>
      <input
        class="form-control"
        required
        type="text"
        name="titulo"
        value="{{titulo}}"
      />
    </div>

    <div class="col-12">
      <label class="form-label" for="texto">Texto da Nota</label>
      <textarea class="form-control" rows="5" name="texto">{{texto}}</textarea>
    </div>

    <div class="col-12">
      <div class="form-check">
        {{#if lida}}
          <input
            class="form-check-input"
            type="checkbox"
            name="status"
            id="status"
            checked
          />
        {{else}}
          <input
            class="form-check-input"
            type="checkbox"
            name="status"
            id="status"
          />
        {{/if}}
        <label class="form-check-label" for="status">
          Nota Lida
        </label>
      </div>
    </div>

    <div class="col-12 d-flex gap-2">
      <button type="submit" class="btn btn-success">Alterar</button>
      <a href="/" class="btn btn-secondary">Cancelar</a>
    </div>

  </form>
</div>