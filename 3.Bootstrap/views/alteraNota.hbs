<nav class="navBack mb-4 p-3 w-100">

  <div class="row align-items-center">

    <div class="col-auto">
      <h1 class="m-0">Notas</h1>
    </div>

    <div class="col">
      <div class="d-flex gap-3 itens-gray">
        <a href="/">Home</a>

        <a href="/sobre">Sobre</a>

        <a href="/nota/cria">Criar Nota</a>

        <a href="/nota/criaNotasTeste">Criar Notas de Teste</a>
      </div>
    </div>

  </div>

</nav>

<div class="ms-5">

  <h2>Alteração de nota de texto</h2>
  <form method="POST" action="/nota/altera/{{chave}}">
    <div class="mb-2">

      <p><label class="form-label" for="chave">Chave</label></p>

      <p><input
          required
          type="text"
          name="chave"
          value="{{chave}}"
          size="30"
          readonly
        /></p>
    </div>

    <div class="mb-2">

      <p><label class="form-label" for="titulo ">Título</label></p>
      <p><input
          required
          type="text"
          name="titulo"
          value="{{titulo}}"
          size="60"
        /></p>
      <div class="mb-2">

      </div>
      <p><label class="form-label" for="import ancia">Importancia da Nota</label></p>
      <p><input
          type="number"
          name="importancia"
          id="importancia"
          max="5"
          min="1"
          value="{{importancia}}"
        /></p>
    </div>
    <div class="mb-2">

      <p><label class="form-label" for="texto">Texto da Nota</label></p>
      <p><textarea rows="5" cols="57" name="texto">{{texto}}</textarea></p>

      <p>
        {{#if lida}}
          <input type="checkbox" name="status" id="status" checked />
        {{else}}
          <input type="checkbox" name="status" id="status" />
        {{/if}}
        <label for="status">Nota Lida</label>
      </p>
    </div>
    <div class="mb-2">
      <a href="/" class="btn btn-danger">Cancelar</a>
      <button type="submit" class="btn btn-success">Criar</button>

    </div>
  </form>

</div>