<h2>Criação de uma nova nota de texto</h2>
<form method="POST" action="/nota/cria">
  <p><label for="chave">Chave</label></p>
  <p><input required type="text" name="chave" value="" size="30" /></p>
  <p><label for="titulo">Título</label></p>
  <p><input required type="text" name="titulo" value="" size="60" /></p>
  <p><label for="importancia">Importancia</label></p>
  <p><input
      type="number"
      name="importancia"
      id="importancia"
      max="5"
      min="1"
      value="1"
    /></p>
  <p><label for="texto">Texto da Nota</label></p>
  <p><textarea rows="5" cols="57" name="texto"></textarea></p>
  <button type="submit">Criar</button>
  <a href="/">
    <button type="button">Cancelar</button></a>
</form>