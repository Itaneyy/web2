<div style="width: 80%; margin: 0 auto">

  <nav align="right" class="nav nav-pills mb-5">
    <a href="/" class="flex-sm-fill text-sm-center nav-link"><i
        class="bi bi-house"
      ></i>Home</a>

    <a href="/ajuda" class="flex-sm-fill text-sm-center nav-link"><i
        class="bi bi-info-square"
      ></i>Ajuda</a>
    <a
      href="/atividade/cria "
      class="flex-sm-fill text-sm-center nav-link "
    >
      <i class="bi bi-envelope-plus"></i>
      Criar nova atividade</a>

    <a href="/prioridadeAlta" class="flex-sm-fill text-sm-center nav-link">
      <i class="bi bi-exclamation-circle"></i>Prioridade Alta</a>

  </nav>
  <h2>Alteração de nota de texto</h2>
  <form method="POST" action="/atividade/altera/{{chave}}">

    <p><label for="chave">ID</label></p>
    <p><input
        required
        type="text"
        name="chave"
        value="{{chave}}"
        size="30"
        readonly
      /></p>

    <p><label for="titulo">Título</label></p>
    <p><input
        required
        type="text"
        name="titulo"
        value="{{tittle}}"
        size="60"
      /></p>

    <p><label for="texto">Descrição da atividade</label></p>
    <p><textarea rows="5" cols="57" name="texto">{{texto}}</textarea></p>

    <p>
      <label for="prioridade">Prioridade da Atividade</label>
    </p>
    <p>

      <select name="prioridade" id="prioridade">
        <option value="Alta">Alta</option>
        <option value="Média" selected>Média</option>
        <option value="Baixa">Baixa</option>
      </select>
    </p>

    <button type="submit" class="btn btn-warning"><i class="bi bi-pencil"></i>Alterar</button>

    <a href="/" class="btn  btn-secondary"><i class="bi bi-x"></i>  
        Cancelar
      </a>
  </form>
</div>