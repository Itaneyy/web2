<div style="width: 80%; margin: 0 auto">

  <nav align="right" class="nav nav-pills mb-5">
    <a href="/" class="flex-sm-fill text-sm-center nav-link"><i
        class="bi bi-house"
      ></i>Home</a>

    <a href="/ajuda" class="flex-sm-fill text-sm-center nav-link"><i
        class="bi bi-info-square"
      ></i>Ajuda</a>
    <a
      href="/atividade/cria "
      class="flex-sm-fill text-sm-center nav-link active"
    >
      <i class="bi bi-envelope-plus"></i>
      Criar nova atividade</a>

    <a href="/prioridadeAlta" class="flex-sm-fill text-sm-center nav-link">
      <i class="bi bi-exclamation-circle"></i>Prioridade Alta</a>

  </nav>

  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">Home</a></li>

      <li class="breadcrumb-item active" aria-current="page">Criar Atividade</li>
    </ol>
  </nav>

  <h2>Criar nova atividade</h2>

  <form action="/atividade/cria" method="POST">

    <div class="mb-3">

      <label class="form-label" for="titulo">Título</label>

      <input
        class="form-control"
        type="text"
        name="titulo"
        id="titulo"
        class="form-control"
        required
      />
    </div>

    <div class="mb-3">
      <label class="form-label" for="desc">Descrição da atividade</label>
      <p>

      <textarea
        name="desc"
        id="desc"
        rows="10"
        style="width: 33%;"
        required
      ></textarea>
      </p>

    </div>

    <p>
      <label class="form-label" for="prioridade">Prioridade da atividade</label>
    </p>
    <select
      name="prioridade"
      id="prioridade"
      class="form-select form-select-lg mb-3"
    >
      <option value="Alta">Alta</option>
      <option value="Média" selected>Média</option>
      <option value="Baixa">Baixa</option>
    </select>

   
      <button type="submit" class="btn btn-primary"><i class="bi bi-check"></i>Criar</button>
      <a href="/" class="btn  btn-secondary"><i class="bi bi-x"></i>  
        Cancelar
      </a>
    </div>
  </form>
</div>