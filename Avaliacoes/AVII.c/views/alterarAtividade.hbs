<h2>Alterar Atividade</h2>
<form method="POST" action="/atividade/alterar/{{ id }}">

  <div class="row">

    <div class="col-lg-2 col-md-3 mb-3">
      <label class="form-label">ID</label>
      <input
        class="form-control"
        type="text"
        name="id"
        value="{{ id }}"
        readonly
      />
    </div>

    <div class="col-lg-5 col-md-9 mb-3">
      <label class="form-label">Título</label>
      <input
        class="form-control"
        type="text"
        name="titulo"
        value="{{ titulo }}"
        required
      />
    </div>

    <div class="col-lg-5 col-md-12 mb-3">
      <label class="form-label">Prioridade</label>

      <select class="form-select" name="prioridade" required>
        <option
          value="Baixa"
          {{#if baixa}}
            selected
          {{/if}}
        >
          Baixa
        </option>
        <option
          value="Média"
          {{#if media}}
            selected
          {{/if}}
        >
          Média
        </option>
        <option
          value="Alta"
          {{#if alta}}
            selected
          {{/if}}
        >
          Alta
        </option>
      </select>

    </div>

    <div class="col-12 mb-3">
      <label class="form-label">Descrição</label>

      <textarea class="form-control" rows="5" name="descricao" required
      >{{descricao}}</textarea>

    </div>

    <div class="col-12">
      <button class="btn btn-warning" type="submit">
        <i class="bi bi-pencil"></i>
        Alterar
      </button>
      <a class="btn btn-secondary" href="/">
        <i class="bi bi-x-lg"></i>
        Cancelar
      </a>
    </div>

  </div>

</form>
