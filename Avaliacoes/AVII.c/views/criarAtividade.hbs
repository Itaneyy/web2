<h2>Criar Atividade</h2>
<form method="POST" action="/atividade/criar">

  <div class="row">

    <div class="col-lg-6 col-md-12 mb-3">
      <label for="titulo" class="form-label">Título</label>
      <input type="text" name="titulo" class="form-control" required />
    </div>

    <div class="col-lg-6 col-md-12 mb-3">
      <label for="prioridade" class="form-label">Prioridade</label>
      <select name="prioridade" class="form-select">
        <option value="Baixa">Baixa</option>
        <option value="Média">Média</option>
        <option value="Alta">Alta</option>
      </select>
    </div>

    <div class="col-12 mb-3">
      <label for="descricao" class="form-label">Descrição da Atividade</label>
      <textarea
        name="descricao"
        class="form-control"
        rows="5"
        required
      ></textarea>
    </div>

    <div class="col-12">
      <button class="btn btn-primary" type="submit"><i class="bi bi-check2"></i>
        Criar</button>
      <a href="/" class="btn btn-secondary"><i class="bi bi-x-lg"></i>
        Cancelar</a>
    </div>

  </div>

</form>