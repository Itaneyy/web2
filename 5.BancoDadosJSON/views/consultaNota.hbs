<nav class="navBack mb-4 p-3 w-100">
  <div class="row align-items-center">

    <div class="col-auto">
      <h1 class="m-0">Notas</h1>
    </div>

    <div class="col d-none d-lg-block">
      <div class="d-flex gap-3 itens-gray">
        <a href="/"> <i class="bi bi-house"></i>Home</a>
        <a href="/sobre"> <i class="bi bi-info-square"></i> Sobre</a>
        <a href="/nota/cria"> <i class="bi bi-envelope-plus"></i>Criar Nota</a>
        <a href="/nota/criaNotasTeste"><i class="bi bi-file-plus"></i>Criar
          Notas de Teste</a>
      </div>
    </div>

    <div class="col text-end d-block d-lg-none">
      <button
        class="btn border-0 p-0 text-dark"
        type="button"
        data-bs-toggle="offcanvas"
        data-bs-target="#menuResponsivo"
      >
        <i class="bi bi-justify fs-2"></i>
      </button>
    </div>

  </div>
</nav>
<div class="offcanvas offcanvas-end" tabindex="-1" id="menuResponsivo">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title">Navegação</h5>
    <button
      type="button"
      class="btn-close"
      data-bs-dismiss="offcanvas"
    ></button>
  </div>
  <div class="offcanvas-body">
    <div class="d-flex flex-column gap-3 itens-gray">
      <a href="/"> <i class="bi bi-house"></i>Home</a>
      <a href="/sobre"> <i class="bi bi-info-square"></i> Sobre</a>
      <a href="/nota/cria"> <i class="bi bi-envelope-plus"></i>Criar Nota</a>
      <a href="/nota/criaNotasTeste"><i class="bi bi-file-plus"></i>Criar Notas
        de Teste</a>
    </div>
  </div>
</div>

<h2 class="titulo">Consulta a Informações da Nota</h2>
<br />
<p><b>{{nota.titulo}}</b></p>
<p>{{nota.texto}}</p>
<p><b>Chave: </b>{{nota.chave}}</p>
<p><b>Importância: </b>{{nota.importancia}}</p>
<hr />
<button
  class="btn btn-danger"
  data-bs-toggle="modal"
  data-bs-target="#modalExclusao"
>Deletar</button>
<a href="/nota/altera/{{nota.chave}}"><button
    class="btn btn-success"
  >Alterar</button></a>
<br /><br /><br />
<a href="/">Voltar</a>
<div class="modal" tabindex="-1" id="modalExclusao">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Exclusão de Nota</h5>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal"
          aria-label="Close"
        ></button>
      </div>
      <div class="modal-body">
        <p>Deseja realmente excluir a nota "{{nota.titulo}}"?</p>
      </div>
      <div class="modal-footer">
        <a href="/nota/deleta/{{nota.chave}}"><button
            type="button"
            class="btn btn-danger"
          >Excluir</button></a>
        <button
          type="button"
          class="btn btn-secondary"
          data-bs-dismiss="modal"
      
        >Cancelar</button>
      </div>
    </div>
  </div>
</div>